## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
		
# Build folders
[Bb]in/
[Oo]bj/

# Build outputs & intermediates
*.exe
*.dll
*.pdb
*.ilk
*.log
*.tlog
*.cache
*.tmp
*.temp

# NuGet
packages/
*.nupkg

# Publish
publish/
*.Publish.xml

# Test results
TestResults/
*.trx
coverage*
*.coverage
*.coveragexml

# IIS Express
IISExpress/
applicationhost.config

# IDEs & tools
.vscode/
.idea/
_ReSharper*/
*.ReSharper.*

# Mono / Xamarin
*.pidb
*.booproj

# Signing keys & secrets
*.snk

# OS files
Thumbs.db
.DS_Store

# Misc
project.lock.json
project.fragment.lock.json